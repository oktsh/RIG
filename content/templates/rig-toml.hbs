# RIG Configuration
# Generated by create-rig v{{rig_version}}
# Edit this file, then run 'rig generate' to regenerate output files.

[project]
name = "{{project.name}}"
preset = "{{project.preset}}"
stack = "{{project.stack}}"

{{#if team}}
[team]
{{#if team.size}}
size = {{team.size}}
{{/if}}
{{/if}}

[agents]
tiers = [{{#each agents.tiers}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
default_memory = "{{agents.default_memory}}"
worker_model = "{{agents.worker_model}}"
oversight_model = "{{agents.oversight_model}}"

[hooks]
pre_commit = [{{#each hooks.pre_commit}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]

[formats]
generate = [{{#each formats.generate}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]

[updates]
channel = "{{updates.channel}}"
auto_check = {{updates.auto_check}}
