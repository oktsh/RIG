{
  "name": "@gyrd/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core engine for GYRD — schemas, generator, updater, doctor. Used by create-gyrd and @gyrd/cli.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "content"],
  "scripts": {
    "prebuild": "rm -rf content && cp -r ../../content content",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oktsh/RIG.git",
    "directory": "packages/core"
  },
  "homepage": "https://gyrd.dev",
  "author": "oktsh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "gyrd",
    "ai-dev",
    "claude",
    "core"
  ],
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.6.2",
    "handlebars": "^4.7.9",
    "log-symbols": "^7.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
